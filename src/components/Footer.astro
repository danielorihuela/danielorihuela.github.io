---
const links = [
	{
		label: "github",
		href: "https://github.com/danielorihuela",
	},
	{
		label: "email",
		href: "mailto:danielorihuelarodriguez@gmail.com",
	},
];

const checks = ["SYS.ONLINE", "COMM.ENCRYPTED"];
---

<footer class="footer">
	<div class="footer-container">
		<div class="text-info-container">
			{
				links.map((link) => (
					<a
						href={link.href}
						class="link"
						target="_blank"
						rel="noopener noreferrer"
					>
						<span />
						{link.label}
					</a>
				))
			}
		</div>

		<div class="text-info-container">
			{
				checks.map((check) => (
					<div class="check-container">
						<span class="light-container">
							<span class="light-pulse" />
							<span class="light" />
						</span>
						<span class="check-label">{check}</span>
					</div>
				))
			}
		</div>
	</div>
</footer>

<style>
	.footer {
		border-top: 1px solid var(--border);
		background-color: var(--bg-dark);
	}

	.footer-container {
		display: flex;
		justify-content: space-between;

		max-width: 60vw;
		margin: 0 auto;
		padding: 1rem 0;
	}

	@media (min-width: 640px) {
		.footer-container {
			flex-direction: row;
		}
	}

	/* Common styles */
	.text-info-container {
		display: flex;
		align-items: center;
		gap: 1.5rem;

		font-size: 0.625rem;
		letter-spacing: 0.1em;
		text-transform: uppercase;
	}

	/* Link styles */
	.link {
		display: flex;
		gap: 0.375rem;

		color: var(--text-body);
		opacity: 0.8;
	}

	.link:hover {
		color: var(--text-bright);
		opacity: 1;
	}

	.link span {
		width: 0.375rem;
		height: 0.625rem;

		background-color: var(--accent);

		opacity: 0;
	}

	.link:hover span {
		opacity: 1;
	}

	/* Status styles */
	.check-container {
		display: flex;
		align-items: center;
		gap: 0.625rem;
	}

	.light-container {
		position: relative;
		display: flex;
		width: 0.375rem;
		height: 0.375rem;
	}

	.light-pulse {
		display: inline-flex;
		width: 100%;
		height: 100%;
		position: absolute;

		background-color: var(--accent);
		opacity: 0.7;
		border-radius: 100%;

		animation: ping 1s cubic-bezier(0, 0, 0.2, 1) infinite;
	}

	@keyframes ping {
		75%,
		100% {
			transform: scale(2);
			opacity: 0;
		}
	}

	.light {
		display: flex;
		border-radius: 100px;
		width: 100%;
		height: 100%;
		background-color: var(--accent);
	}

	.check-label {
		color: var(--text-body);
		opacity: 0.8;
		font-weight: bold;
	}
</style>
