---
const buildHash = Math.random().toString(16).substring(2, 8).toUpperCase();
---

<footer class="border-t border-cyber-border bg-cyber-black/80">
	<div class="max-w-6xl mx-auto px-4 lg:px-6 py-4">
		<div class="flex flex-col sm:flex-row items-center justify-between gap-4 font-mono">
			{/* Contact links */}
			<div class="flex items-center gap-6 text-[10px] uppercase tracking-widest leading-none">
				<a
					href="https://github.com/danielorihuela"
					class="group flex items-center gap-1.5 text-terminal-text opacity-60 hover:text-terminal-bright hover:opacity-100 transition-all duration-300"
					target="_blank"
					rel="noopener noreferrer"
				>
					<span class="w-1.5 h-2.5 bg-accent opacity-0 group-hover:opacity-100 transition-all duration-300"></span>
					github
				</a>
				<a
					href="mailto:danielorihuelarodriguez@gmail.com"
					class="group flex items-center gap-1.5 text-terminal-text opacity-60 hover:text-terminal-bright hover:opacity-100 transition-all duration-300"
				>
					<span class="w-1.5 h-2.5 bg-accent opacity-0 group-hover:opacity-100 transition-all duration-300"></span>
					email
				</a>
			</div>

			{/* Status */}
			<div class="flex items-center gap-6 text-[10px] uppercase tracking-widest">
				<div class="hidden sm:flex items-center gap-2 text-terminal-text opacity-40">
					<span>BUILD_REF</span>
					<span class="text-terminal-bright ml-1 font-bold">0x{buildHash}</span>
				</div>
				<div class="flex items-center gap-2.5">
					<span class="relative flex h-1.5 w-1.5">
						<span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-accent opacity-60"></span>
						<span class="relative inline-flex rounded-full h-1.5 w-1.5 bg-accent shadow-[0_0_8px_rgba(0,212,255,0.8)]"></span>
					</span>
					<span class="text-terminal-text opacity-80 font-bold">SYS.ONLINE</span>
				</div>
			</div>
		</div>
	</div>
</footer>
