---
interface Props {
	idx: number;
	prCount: number;
	stack: string;
}

const { idx, prCount, stack } = Astro.props;
---

<div class="project-sidebar">
	<div class="meta-item">
		<span class="meta-label">ID_REF</span>
		<span class="meta-value">
			0x{(0x7f4c0000 + idx * 0x10).toString(16).toUpperCase()}
		</span>
	</div>
	<div class="meta-item">
		<span class="meta-label">PR_CONTRIB</span>
		<span class="meta-value">#{prCount.toString().padStart(2, "0")}</span>
	</div>
	<div class="meta-item">
		<span class="meta-label">BASE_STACK</span>
		<span class="meta-value">{stack}</span>
	</div>
</div>

<style>
	.project-sidebar {
		flex-shrink: 0;
		background-color: rgba(255, 255, 255, 0.02);
		padding: 1rem;
		display: flex;
		gap: 1rem 1.5rem;
		border-bottom: 1px solid rgba(28, 32, 53, 0.1);
	}

	.meta-item {
		display: flex;
		flex-direction: column;
		gap: 0.375rem;
	}

	.meta-label {
		font-size: 0.75rem;
		letter-spacing: 0.05em;
		opacity: 0.6;
		font-weight: 700;
	}

	.meta-value {
		font-size: 0.875rem;
		font-family: "Share Tech Mono", monospace;
	}

	@media (min-width: 640px) {
		.project-sidebar {
			width: 8rem;
			flex-direction: column;
			gap: 1.25rem;
		}
	}
</style>
