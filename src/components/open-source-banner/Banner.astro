---
import TerminalWindow from "../TerminalWindow.astro";
import Metadata from "./Metadata.astro";
import PrLog from "./PrLog.astro";
import SocialLink from "../SocialLink.astro";

interface PrInfo {
	id: number;
	title?: string;
}

interface Props {
	idx: number;
	name: string;
	description: string;
	image: string;
	url: string;
	prs: PrInfo[];
	stack: string;
}

const { idx, name, description, image, url, prs, stack } = Astro.props;
---

<TerminalWindow class="project-card group">
	<Metadata idx={idx} prCount={prs.length} stack={stack} />

	<div class="project-content">
		<div class="project-header">
			<SocialLink href={url} image={image} class="project-icon-wrapper" />
			<a
				href={url}
				class="project-title"
				target="_blank"
				rel="noopener noreferrer"
			>
				{name}
			</a>
		</div>

		<p class="project-description">
			{description}
		</p>

		<PrLog url={url} prs={prs} />
	</div>
</TerminalWindow>

<style>
	.project-card {
		display: flex;
		flex-direction: column;
		transition: all 0.3s ease;
	}

	.project-card:hover {
		border-color: var(--accent-glow);
		background-color: var(--accent-glow-dim);
	}

	.project-content {
		padding: 1.5rem;
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}

	.project-header {
		display: flex;
		align-items: center;
		gap: 1rem;
	}

	.project-icon-wrapper {
		width: 3rem;
		height: 3rem;
		transition: transform 0.3s ease;
	}

	.project-title {
		font-size: 1.5rem;
		color: var(--text-bright);
		transition: color 0.2s ease;
	}

	.project-card:hover .project-title {
		color: #ffffff;
	}

	.project-description {
		font-size: 0.875rem;
		line-height: 1.625;
		margin: 0;
	}

	@media (min-width: 640px) {
		.project-card {
			flex-direction: row;
		}
	}
</style>
