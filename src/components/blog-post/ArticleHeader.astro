---
import FormattedDate from "../FormattedDate.astro";

interface Props {
	title: string;
	publishdate: Date;
}

const { title, publishdate } = Astro.props;
---

<div class="post-article-header">
	<div class="post-article-meta">
		<span class="post-article-hashtag">#</span>
		<FormattedDate date={publishdate} />
	</div>

	<h1 class="post-article-title">
		{title}
	</h1>
</div>

<style>
	.post-article-header {
		padding: 1rem 1rem 0rem;
	}

	.post-article-meta {
		margin-bottom: 1rem;
		font-family: "Share Tech Mono", monospace;
		font-size: 0.75rem;
		color: var(--text-dim);
	}

	.post-article-hashtag {
		color: var(--accent);
	}

	.post-article-title {
		font-size: 1.8em;
	}

	@media (min-width: 640px) {
		.post-article-header {
			padding: 1rem 0.5rem 0rem;
		}

		.post-article-title {
			font-size: 2.5em;
		}
	}
</style>
