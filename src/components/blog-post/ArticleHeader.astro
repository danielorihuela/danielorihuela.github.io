---
import FormattedDate from "../FormattedDate.astro";

interface Props {
	title: string;
	publishdate: Date;
}

const { title, publishdate } = Astro.props;
---

<div class="post-article-header">
	<div class="post-article-meta">
		<span class="post-article-hashtag">#</span>
		<FormattedDate date={publishdate} />
	</div>

	<h1 class="post-article-title">
		{title}
	</h1>

	<div class="post-article-divider"></div>
</div>

<style>
	.post-article-header {
		padding: 2.5rem 1rem 2rem;
	}

	.post-article-header:last-child {
		border-bottom-width: 0px;
	}

	@media (min-width: 1024px) {
		.post-article-header {
			padding-left: 1.5rem;
			padding-right: 1.5rem;
		}
	}

	.post-article-meta {
		display: flex;
		align-items: center;
		gap: 0.75rem;
		margin-bottom: 1rem;
		font-family: "Share Tech Mono", monospace;
		font-size: 0.75rem;
		color: var(--text-dim);
	}

	.post-article-hashtag {
		color: var(--accent);
	}

	.post-article-title {
		font-size: 2.5em;
	}

	@media (max-width: 720px) {
		.post-article-title {
			font-size: 1.8em;
		}
	}

	.post-article-divider {
		width: 4rem;
		height: 0.25rem;
		background-color: rgba(0, 212, 255, 0.3);
		margin-bottom: 2.5rem;
	}
</style>
