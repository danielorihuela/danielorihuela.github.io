---
interface Props {
	slug: string;
}

const { slug } = Astro.props;
---

<div class="post-terminal-top-bar">
	<div class="post-terminal-top-bar-left">
		<span class="post-terminal-badge">READ_ONLY</span>
		<span class="post-terminal-separator">|</span>
		<span class="post-terminal-filename">{slug}.md</span>
	</div>
	<div class="post-terminal-top-bar-right">
		Lines: <span class="post-terminal-value">AUTO</span>
		| Encoding: <span class="post-terminal-value">UTF-8</span>
	</div>
</div>

<style>
	.post-terminal-top-bar {
		display: flex;
		justify-content: space-between;
		align-items: center;
		background-color: var(--accent-extra-dim);
		padding: 0.5rem 1rem;

		font-family: "Share Tech Mono", monospace;
		font-size: 0.8em;
	}

	.post-terminal-top-bar::before {
		content: "●";
		color: var(--accent);
		font-size: 0.8em;
	}

	.post-terminal-badge {
		color: var(--accent);
		font-size: 0.8em;
	}

	.post-terminal-separator {
		color: var(--text-dim);
	}

	.post-terminal-filename {
		color: var(--text-bright);
		font-size: 0.8rem;
		font-family: "Courier New", monospace;
	}

	.post-terminal-top-bar-right {
		display: none;
	}

	.post-terminal-value {
		color: var(--accent);
	}

	@media (min-width: 640px) {
		.post-terminal-top-bar-left {
			display: flex;
			align-items: center;
			gap: 0.5rem;
		}

		.post-terminal-top-bar-right {
			display: block;
			font-size: 0.8em;
			color: var(--text-dim);
			font-family: "Courier New", monospace;
		}
	}
</style>
