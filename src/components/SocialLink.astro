---
interface Props {
	href: string;
	image: string;
	class?: string;
}

const { href, image, class: className } = Astro.props;
---

<a
	href={href}
	class:list={["social-link", className]}
	target="_blank"
	rel="noopener noreferrer"
>
	<img src={image} alt="" />
</a>

<style>
	.social-link {
		overflow: hidden;
		border-radius: 6px;
		border: 1px solid var(--border);
		background: var(--bg-panel);
		padding: 0.4em;
		transition: border-color 0.3s ease;
	}

	.social-link:hover {
		border-color: var(--accent);
	}

	.social-link img {
		filter: grayscale(100%) brightness(0.7);
		transition: filter 0.3s ease;
	}

	.social-link:hover img {
		filter: grayscale(0%) brightness(1);
	}

	.social-link::before {
		content: "";
		position: absolute;
		left: 0;
		top: -2px;
		width: 100%;
		height: 2px;
		background: linear-gradient(
			90deg,
			transparent,
			var(--accent),
			transparent
		);
	}

	.social-link:hover::before {
		animation: sweepLine 2s ease-in-out infinite;
	}

	@keyframes sweepLine {
		0% {
			top: -2px;
		}
		100% {
			top: 100%;
		}
	}
</style>
