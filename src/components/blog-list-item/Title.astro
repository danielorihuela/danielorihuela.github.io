---
interface Props {
	title: string;
}

const { title } = Astro.props;
---

<div class="title-column">
	<span class="title-symbol">&gt;</span>
	<h2 class="title-text">{title}</h2>
</div>

<style>
	.title-column {
		display: flex;
		align-items: center;
		flex: 1;
		min-width: 0;
		gap: 0.5rem;
	}

	.title-symbol {
		display: none;
	}

	@media (min-width: 640px) {
		.title-symbol {
			display: inline;
			margin-top: 0;
			color: #00d4ff;
			transition: transform 300ms;
		}
	}

	.title-text {
		font-size: 0.875rem;
		margin: 0;
	}

	@media (min-width: 768px) {
		.title-text {
			font-size: 1rem;
		}
	}
</style>
