---
const navItems = [
	{ name: "blog", path: "/", cmd: "blog" },
	{ name: "oss", path: "/open-source/", cmd: "contrib" },
];

const currentPath = Astro.url.pathname;
---

<header>
	<nav class="header-nav">
		<div class="nav-container">
			<div class="nav-content">
				<a href="/" class="logo-link">
					<span class="logo-user">danielorihuela</span><span
						class="logo-at">@</span
					><span class="logo-host">dev</span><span class="logo-colon"
						>:</span
					><span class="logo-tilde">~</span>
				</a>

				<div class="desktop-nav">
					{
						navItems.map((item) => (
							<a
								href={item.path}
								class={`nav-link ${currentPath === item.path ? "active" : ""}`}
							>
								<span class="nav-prefix">./</span>
								{item.cmd}
							</a>
						))
					}
				</div>

				<button
					id="mobile-menu-button"
					class="mobile-menu-btn"
					aria-label="Toggle menu"
				>
					<span id="menu-label">[menu]</span>
				</button>
			</div>

			<div id="mobile-menu" class="mobile-menu">
				{
					navItems.map((item) => (
						<a
							href={item.path}
							class={`mobile-nav-link ${currentPath === item.path ? "active" : ""}`}
						>
							<span class="mobile-nav-prefix">_</span>
							{item.cmd}
						</a>
					))
				}
			</div>
		</div>
	</nav>

	<script>
		document.addEventListener("DOMContentLoaded", () => {
			const btn = document.getElementById("mobile-menu-button");
			const label = document.getElementById("menu-label");
			if (!btn || !label) return;

			btn.addEventListener("click", () => {
				const menu = document.getElementById("mobile-menu");
				if (!menu) return;

				if (menu.classList.contains("is-open")) {
					menu.classList.remove("is-open");
					label.textContent = "[menu]";
				} else {
					menu.classList.add("is-open");
					label.textContent = "[close]";
				}
			});
		});
	</script>
</header>

<style>
	.header-nav {
		position: fixed;
		left: 0;
		right: 0;
		z-index: 50;
		background-color: rgba(8, 9, 14, 0.95);
		backdrop-filter: blur(4px);
		border-bottom: 1px solid var(--border);
	}

	.nav-container {
		padding: 0 1rem;
	}

	.nav-content {
		display: flex;
		align-items: center;
		justify-content: space-between;
		height: 3.5rem;
	}

	.logo-link {
		font-family: "Share Tech Mono", monospace;
		font-size: 0.875rem;
		transition: color 0.3s ease;
	}

	.logo-link:hover {
		color: var(--accent);
	}

	.logo-user {
		font-weight: bold;
	}

	.logo-at {
		color: var(--text-body);
	}

	.logo-host {
		color: var(--text-bright);
	}

	.logo-colon {
		color: var(--text-body);
	}

	.logo-tilde {
		color: var(--text-body);
	}

	.desktop-nav {
		display: none;
		gap: 0.25rem;
	}

	@media (min-width: 640px) {
		.desktop-nav {
			display: flex;
		}
	}

	.nav-link {
		font-family: "Share Tech Mono", monospace;
		font-size: 0.75rem;
		padding: 0.375rem 0.75rem;
		border-radius: 0.25rem;
		transition: all 0.3s ease;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		color: var(--text-body);
		opacity: 0.6;
		display: flex;
		border: 1px solid transparent;
	}

	.nav-link:hover {
		color: var(--accent);
		background-color: var(--accent-extra-dim);
		opacity: 1;
	}

	.nav-link.active {
		color: var(--accent);
		background-color: rgba(0, 212, 255, 0.1);
		border-color: rgba(0, 212, 255, 0.3);
		opacity: 1;
	}

	.nav-prefix {
		transition: all 0.3s ease;
	}

	.mobile-menu-btn {
		background: transparent;
		border: none;
		cursor: pointer;
		color: var(--text-body);
		transition: all 0.3s ease;
		font-family: "Share Tech Mono", monospace;
		font-size: 0.75rem;
		text-transform: uppercase;
		letter-spacing: 0.1em;
	}

	@media (min-width: 640px) {
		.mobile-menu-btn {
			display: none;
		}
	}

	.mobile-menu-btn:hover {
		color: var(--accent);
	}

	.mobile-menu {
		transition: all 0.5s ease;
		opacity: 0;
	}

	@media (min-width: 640px) {
		.mobile-menu {
			display: none;
		}
	}

	.mobile-menu.is-open {
		opacity: 1;
	}

	.mobile-nav-link {
		display: block;
		font-family: "Share Tech Mono", monospace;
		font-size: 0.75rem;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		padding: 0.875rem 1rem;
		transition: all 0.3s ease;
		color: var(--text-body);
		opacity: 0.6;
		border-left: 2px solid transparent;
	}

	.mobile-nav-link:hover {
		color: var(--accent);
		background-color: var(--accent-extra-dim);
		opacity: 1;
		text-shadow: none;
	}

	.mobile-nav-link.active {
		color: var(--accent);
		background-color: rgba(0, 212, 255, 0.1);
		border-left-color: var(--accent);
		opacity: 1;
	}

	.mobile-nav-prefix {
		color: var(--accent);
		margin-right: 0.75rem;
	}
</style>
