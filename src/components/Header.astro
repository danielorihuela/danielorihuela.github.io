---
const navItems = [
	{ name: "blog", path: "/", cmd: "blog" },
	{ name: "oss", path: "/open-source/", cmd: "contrib" },
];
const currentPath = Astro.url.pathname;
---

<header>
	<nav>
		<div class="nav-content">
			<a href="/" class="logo">danielorihuela<span>@dev:~</span></a>
			<div class="nav-links desktop">
				{
					navItems.map((i) => (
						<a
							href={i.path}
							class:list={[
								"link",
								{ active: currentPath === i.path },
							]}
						>
							./{i.cmd}
						</a>
					))
				}
			</div>
			<button id="menu-toggle">[menu]</button>
		</div>
		<div id="mobile-menu" class="nav-links mobile">
			{
				navItems.map((i) => (
					<a
						href={i.path}
						class:list={[
							"link",
							{ active: currentPath === i.path },
						]}
					>
						- {i.cmd}
					</a>
				))
			}
		</div>
	</nav>

	<script>
		const button = document.getElementById("menu-toggle");
		const menu = document.getElementById("mobile-menu");
		button?.addEventListener("click", () => {
			const open = menu?.classList.toggle("open");
			button.textContent = open ? "[close]" : "[menu]";
		});
	</script>
</header>

<style>
	nav {
		position: fixed;
		inset: 0 0 auto 0;
		z-index: 50;
		background: rgba(8, 9, 14, 0.95);
		backdrop-filter: blur(4px);
		border-bottom: 1px solid var(--border);
		padding: 0 1rem;
		font-family: "Share Tech Mono", monospace;
	}

	.nav-content {
		display: flex;
		align-items: center;
		justify-content: space-between;
		height: 3.5rem;
	}

	.logo {
		font-size: 0.875rem;

		span {
			color: var(--text-bright);
		}
	}

	.nav-links {
		&.desktop {
			display: none;
			gap: 0.25rem;
			@media (min-width: 640px) {
				display: flex;
			}
		}

		&.mobile {
			display: flex;
			flex-direction: column;
			max-height: 0;
			overflow: hidden;
			transition: 0.5s ease;

			&.open {
				max-height: 24rem;
				opacity: 1;
				padding-bottom: 1rem;

				@media (min-width: 640px) {
					display: none;
				}
			}

			.link {
				padding: 0.875rem 1rem;
				border-left: 2px solid transparent;
			}

			.link:hover,
			.link.active {
				border-left-color: var(--accent);
			}
		}
	}

	.link {
		font-size: 0.75rem;
		text-transform: uppercase;
		color: var(--text-body);
		opacity: 0.6;
		transition: all 0.3s ease;
		padding: 0.375rem 0.75rem;
		letter-spacing: 0.05em;
		border: 1px solid transparent;

		&:hover {
			color: var(--accent);
			background-color: var(--accent-extra-dim);
			opacity: 1;
		}

		&.active {
			color: var(--accent);
			background-color: var(--accent-glow-dim);
			border-color: var(--accent);
			border-radius: 0.25rem;
			opacity: 1;
		}
	}

	#menu-toggle {
		background: none;
		border: none;
		color: var(--text-body);
		font:
			0.75rem "Share Tech Mono",
			monospace;
		text-transform: uppercase;
		cursor: pointer;
		@media (min-width: 640px) {
			display: none;
		}
	}
</style>
