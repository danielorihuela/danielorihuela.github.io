---
const navItems = [
	{ name: "blog", path: "/", cmd: "blog" },
	{ name: "oss", path: "/open-source/", cmd: "contrib" },
];

const currentPath = Astro.url.pathname;
---

<header>
	<nav class="fixed top-0 left-0 right-0 z-50 bg-cyber-black/95 backdrop-blur-sm border-b border-cyber-border">
		<div class="max-w-6xl mx-auto px-4 lg:px-6">
			<div class="flex items-center justify-between h-14">
				{/* Terminal Prompt Logo */}
				<a
					href="/"
					class="font-display text-sm text-terminal-text hover:text-accent transition-colors duration-200 group"
				>
					<span class="text-accent font-bold">daniel</span><span class="text-terminal-dim">@</span><span class="text-terminal-bright">oss</span><span class="text-terminal-dim">:</span><span class="text-terminal-text">~</span>
				</a>

				{/* Desktop Navigation */}
				<div class="hidden md:flex items-center gap-1">
					{navItems.map((item) => (
						<a
							href={item.path}
							class={`font-display text-sm px-3 py-1.5 rounded transition-all duration-200 ${
								currentPath === item.path
									? "text-accent bg-accent/10 border border-accent/30"
									: "text-terminal-dim hover:text-accent hover:bg-accent/5"
							}`}
						>
							<span class="text-terminal-dim mr-1">./</span>{item.cmd}
						</a>
					))}
				</div>

				{/* Mobile menu button */}
				<button
					id="mobile-menu-button"
					class="md:hidden text-terminal-dim hover:text-accent transition-colors duration-200 font-display text-sm"
					aria-label="Toggle menu"
				>
					<span id="menu-label">[menu]</span>
				</button>
			</div>

			{/* Mobile Navigation */}
			<div
				id="mobile-menu"
				class="md:hidden overflow-hidden transition-all duration-300 max-h-0 opacity-0"
			>
				<div class="py-2 border-t border-cyber-border">
					{navItems.map((item) => (
						<a
							href={item.path}
							class={`block font-display text-sm px-4 py-2.5 transition-all duration-200 ${
								currentPath === item.path
									? "text-accent bg-accent/10"
									: "text-terminal-dim hover:text-accent hover:bg-accent/5"
							}`}
						>
							<span class="text-accent mr-2">&gt;</span>{item.cmd}
						</a>
					))}
				</div>
			</div>
		</div>
	</nav>

	<script>
		document.addEventListener("DOMContentLoaded", () => {
			const btn = document.getElementById("mobile-menu-button");
			const label = document.getElementById("menu-label");
			if (!btn || !label) return;

			btn.addEventListener("click", () => {
				const menu = document.getElementById("mobile-menu");
				if (!menu) return;

				if (menu.classList.contains("max-h-0")) {
					menu.classList.remove("max-h-0", "opacity-0");
					menu.classList.add("max-h-96", "opacity-100");
					label.textContent = "[close]";
				} else {
					menu.classList.remove("max-h-96", "opacity-100");
					menu.classList.add("max-h-0", "opacity-0");
					label.textContent = "[menu]";
				}
			});
		});
	</script>
</header>
