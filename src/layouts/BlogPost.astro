---
import { Image } from "astro:assets";
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import FormattedDate from "../components/FormattedDate.astro";

interface Props {
	title: string;
	description: string;
	publishdate: Date;
	cover: any;
	slug: string;
}

const { title, description, publishdate, cover, slug } = Astro.props;
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} image={cover?.src} />
		<style is:global>
			/* Table of Contents & List Fixes */
			.article-content ul, 
			.article-content ol {
				margin: 1.5em 0;
			}
			
			.article-content ul ul, 
			.article-content ul ol,
			.article-content ol ul,
			.article-content ol ol {
				margin: 0.5em 0 0.5em 1.5em;
				padding-left: 0.5em;
				border-left: 1px solid var(--border);
			}

			.article-content li {
				margin-bottom: 0.5em;
			}

			/* Image Handling */
			.article-content img {
				margin: 2em auto;
				border: 1px solid var(--border);
				box-shadow: 0 0 20px rgba(0, 0, 0, 0.4);
			}

			/* Typography & Spacing */
			/* Typography & Spacing */
			.article-content h1,
			.article-content h2,
			.article-content h3,
			.article-content h4,
			.article-content h5,
			.article-content h6 {
				font-family: 'Share Tech Mono', monospace;
				margin-top: 2.5em;
				margin-bottom: 1.2em;
				line-height: 1.2;
				letter-spacing: 0.05em;
				display: flex;
				align-items: baseline;
				gap: 0.5em;
				color: var(--accent);
			}

			.article-content h1 { font-size: 2.2em; text-transform: uppercase; font-weight: bold; }
			.article-content h1::before { content: ">"; opacity: 0.8; }

			.article-content h2 { font-size: 1.8em; text-transform: uppercase; }
			.article-content h2::before { content: ">>"; opacity: 0.7; }

			.article-content h3 { font-size: 1.4em; text-transform: uppercase; }
			.article-content h3::before { content: ">>>"; opacity: 0.6; }

			.article-content h4 { font-size: 1.2em; }
			.article-content h4::before { content: ">>>>"; opacity: 0.5; }

			.article-content h5 { font-size: 1.1em; color: var(--accent-dim); }
			.article-content h5::before { content: ">>>>>"; opacity: 0.4; }

			.article-content h6 { font-size: 1em; color: var(--accent-dim); }
			.article-content h6::before { content: ">>>>>>"; opacity: 0.3; }

			.article-content p {
				color: var(--text-body);
				line-height: 1.8;
				margin-bottom: 1.5em;
			}

			.article-content a {
				color: var(--accent);
				text-decoration: none;
				border-bottom: 1px solid rgba(0, 212, 255, 0.2);
				transition: all 0.2s ease;
			}

			.article-content a:hover {
				color: #fff;
				border-bottom-color: var(--accent);
				text-shadow: 0 0 8px var(--accent-glow);
			}

			/* High-Tech Elegant Table of Contents (ToC) */
			/* Targets the first list in the article content */
			.article-content > ul:first-of-type {
				list-style: none;
				padding: 1.5rem 2rem;
				margin: 2.5rem 0 4rem 0;
				border: 1px solid var(--border);
				background: rgba(0, 212, 255, 0.02);
				position: relative;
				display: block; /* Full width */
				width: 100%;
				box-shadow: inset 0 0 20px rgba(0, 212, 255, 0.02);
			}

			.article-content > ul:first-of-type::before {
				content: "BRANCH_TABLE";
				display: block;
				font-size: 0.65rem;
				color: var(--accent);
				margin-bottom: 1.5rem;
				font-weight: bold;
				letter-spacing: 0.4em;
				opacity: 0.8;
			}

			.article-content > ul:first-of-type li {
				position: relative;
				padding-left: 2rem;
				margin-bottom: 0.8rem;
				transition: transform 0.2s ease;
			}

			.article-content > ul:first-of-type li:hover {
				transform: translateX(4px);
			}

			.article-content > ul:first-of-type li::before {
				content: "[+]";
				position: absolute;
				left: 0;
				color: var(--text-dim);
				font-family: 'Share Tech Mono', monospace;
				font-size: 0.8rem;
				transition: all 0.2s ease;
			}

			.article-content > ul:first-of-type li:hover::before {
				content: "[*]";
				color: var(--accent);
				text-shadow: 0 0 10px var(--accent);
			}

			.article-content > ul:first-of-type a {
				text-transform: uppercase;
				font-size: 0.9rem;
				letter-spacing: 0.1em;
				border-bottom: none !important;
				color: var(--text-body);
			}

			.article-content > ul:first-of-type a:hover {
				color: #fff;
				text-shadow: 0 0 12px var(--accent);
			}

			/* Code Snippets */
			.article-content pre {
				margin: 2em -1.5em;
				padding: 1.5em;
				background-color: #0c0d14 !important;
				border-top: 1px solid var(--border);
				border-bottom: 1px solid var(--border);
				position: relative;
			}

			@media (min-width: 768px) {
				.article-content pre {
					margin: 2em 0;
					border: 1px solid var(--border);
					border-radius: 4px;
				}
			}

			/* Custom Divider */
			.article-content hr {
				border: none;
				height: 1px;
				background: linear-gradient(to right, transparent, var(--border), transparent);
				margin: 3em 0;
				position: relative;
				overflow: visible;
			}

			.article-content hr::after {
				content: '[---]';
				position: absolute;
				left: 50%;
				top: 50%;
				transform: translate(-50%, -50%);
				background: var(--bg-dark);
				padding: 0 1em;
				font-family: 'Share Tech Mono', monospace;
				font-size: 0.7em;
				color: var(--text-dim);
			}
		</style>
	</head>

	<body class="bg-cyber-black min-h-screen flex flex-col">
		<Header />
		<article class="flex-1 pt-24 pb-20">
			<div class="max-w-4xl mx-auto px-4 lg:px-8">
				{/* Terminal command prompt - Matching Home page style */}
				<div class="font-display text-xs md:text-sm mb-8 mt-4 border-b border-cyber-border pb-4 flex items-center gap-2">
					<span class="text-accent font-bold">$</span>
					<span class="text-terminal-bright font-bold">cat ./blog/{slug}.md</span>
				</div>

				<div class="terminal-window shadow-2xl">
					<div class="terminal-header flex justify-between items-center bg-accent/5 border-b border-cyber-border px-4 py-2">
						<div class="flex items-center gap-2">
							<span class="text-accent text-[10px]">READ_ONLY</span>
							<span class="text-terminal-dim">|</span>
							<span class="text-terminal-bright text-xs font-mono">{slug}.md</span>
						</div>
						<div class="text-[10px] text-terminal-dim font-mono hidden sm:block">
							Lines: <span class="text-accent">AUTO</span> | Encoding: <span class="text-accent">UTF-8</span>
						</div>
					</div>
					
					<div class="terminal-body p-0">
						{/* Cover image - Full display, no cropping */}
						{cover && (
							<div class="w-full bg-black/40 border-b border-cyber-border overflow-hidden">
								<Image
									class="w-full h-auto max-h-[500px] object-contain mx-auto"
									src={cover}
									alt=""
									quality={100}
								/>
							</div>
						)}

						{/* Article header */}
						<div class="px-4 lg:px-6 pt-10 pb-8 last:border-b-0">
							<div class="flex items-center gap-3 mb-4 font-display text-xs text-terminal-dim">
								<span class="text-accent">#</span>
								<FormattedDate date={publishdate} />
							</div>
							
							<h1 class="text-3xl md:text-5xl font-display text-white mb-6 leading-tight">
								{title}
							</h1>
							
							<div class="w-16 h-1 bg-accent/30 mb-10"></div>
						</div>

						{/* Article content */}
						<div class="article-content px-4 lg:px-6 pb-12 text-terminal-text">
							<slot />
						</div>
					</div>
				</div>
			</div>
		</article>
		<Footer />
	</body>
</html>
