---
import { Image } from "astro:assets";
import TerminalHeader from "../components/blog-post/TerminalHeader.astro";
import ArticleHeader from "../components/blog-post/ArticleHeader.astro";
import BaseLayout from "./BaseLayout.astro";
import Panel from "../components/Panel.astro";
import Command from "../components/Command.astro";
import "../styles/code-snippet.css";

interface Props {
	title: string;
	description: string;
	publishdate: Date;
	cover: any;
	slug: string;
}

const { title, description, publishdate, cover, slug } = Astro.props;
---

<BaseLayout
	title={title}
	description={description}
	image={cover?.src}
	bodyClass="blog-layout-body"
>
	<article class="blog-article-wrapper">
		<div class="blog-container">
			<Command command={`cat ./blog/${slug}.md`} />

			<Panel class="blog-shadow">
				<TerminalHeader slug={slug} />

				<div class="terminal-body blog-terminal-body">
					<ArticleHeader title={title} publishdate={publishdate} />

					{
						cover && (
							<div class="blog-cover-wrapper">
								<Image
									class="blog-cover-image"
									src={cover}
									alt=""
									quality={100}
								/>
							</div>
						)
					}

					<div class="article-content blog-article-content">
						<slot />
					</div>
				</div>
			</Panel>
		</div>
	</article>
</BaseLayout>

<style is:global>
	/* Table of Contents & List Fixes */
	.article-content ul {
		list-style-type: none;
		margin: 1.5em 0;
	}

	.article-content ul ul,
	.article-content ul ol,
	.article-content ol ul,
	.article-content ol ol {
		margin: 0.5em 0 0.5em 1.5em;
		padding-left: 0.5em;
		border-left: 1px solid var(--border);
	}

	.article-content li {
		margin-bottom: 0.5em;
	}

	.article-content ul > li {
		position: relative;
		padding-left: 1.5rem;
	}

	.article-content ul > li::before {
		content: ">";
		position: absolute;
		left: 0;
		color: var(--accent);
		font-weight: bold;
		opacity: 0.7;
	}

	/* Image Handling */
	.article-content img {
		display: flex;
		max-width: 100%;
		height: auto;
		margin: 0 auto;
		border: 1px solid var(--border);
		box-shadow: 0 0 20px rgba(0, 0, 0, 0.4);
	}

	/* Typography & Spacing */
	.article-content h1,
	.article-content h2,
	.article-content h3,
	.article-content h4,
	.article-content h5,
	.article-content h6 {
		font-family: "Share Tech Mono", monospace;
		margin-top: 2.5em;
		margin-bottom: 1.2em;
		line-height: 1.2;
		letter-spacing: 0.05em;
		display: flex;
		align-items: baseline;
		gap: 0.5em;
		color: var(--accent);
	}

	.article-content h1 {
		font-size: 2.2em;
		text-transform: uppercase;
		font-weight: bold;
	}
	.article-content h1::before {
		content: ">";
		opacity: 0.8;
	}

	.article-content h2 {
		font-size: 1.8em;
		text-transform: uppercase;
	}
	.article-content h2::before {
		content: ">>";
		opacity: 0.7;
	}

	.article-content h3 {
		font-size: 1.4em;
		text-transform: uppercase;
	}
	.article-content h3::before {
		content: ">>>";
		opacity: 0.6;
	}

	.article-content h4 {
		font-size: 1.2em;
	}
	.article-content h4::before {
		content: ">>>>";
		opacity: 0.5;
	}

	.article-content h5 {
		font-size: 1.1em;
		color: var(--accent-dim);
	}
	.article-content h5::before {
		content: ">>>>>";
		opacity: 0.4;
	}

	.article-content h6 {
		font-size: 1em;
		color: var(--accent-dim);
	}
	.article-content h6::before {
		content: ">>>>>>";
		opacity: 0.3;
	}

	.article-content p {
		color: var(--text-body);
		line-height: 1.8;
		margin-bottom: 1.5em;
	}

	.article-content a {
		color: var(--accent);
		text-decoration: none;
		border-bottom: 1px solid rgba(0, 212, 255, 0.2);
		transition: all 0.2s ease;
	}

	.article-content a:hover {
		color: #fff;
		border-bottom-color: var(--accent);
		text-shadow: 0 0 8px var(--accent-glow);
	}

	/* Inline Code */
	.article-content :not(pre) > code {
		padding: 2px 6px;
		background-color: rgba(0, 212, 255, 0.06);
		border: 1px solid var(--border);
		border-radius: 3px;
		color: var(--accent);
		font-family: "IBM Plex Mono", monospace;
		font-size: 0.9em;
	}

	/* Blockquote */
	.article-content blockquote {
		border-left: 3px solid var(--accent);
		padding: 0.5em 0 0.5em 1.5em;
		margin: 1.5em 0;
		background: rgba(0, 212, 255, 0.03);
		color: var(--text-dim);
		font-style: italic;
	}

	/* Tables */
	.article-content table {
		width: 100%;
		table-layout: fixed;
		border-collapse: collapse;
		color: var(--text-body);
		margin: 2em 0;
	}

	.article-content table,
	.article-content th,
	.article-content td {
		border: 1px solid var(--border);
	}

	.article-content th {
		background: var(--accent-extra-dim);
		color: var(--accent);
		font-family: "Share Tech Mono", monospace;
		text-transform: uppercase;
		font-size: 0.85em;
		letter-spacing: 0.05em;
		padding: 0.75em;
	}

	.article-content td {
		padding: 0.75em;
	}

	/* Hacker Elegant Table of Contents (ToC) — "Vertical Manifest" */
	/* Targets the first list in the article content */
	.article-content > ul:first-of-type {
		list-style: none;
		margin: 3.5rem 0;
	}

	.article-content > ul:first-of-type li {
		position: relative;
		padding-left: 3.5rem;
		margin-bottom: 1.2rem;
		transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
		counter-increment: toc-counter;
	}

	.article-content > ul:first-of-type li::before {
		position: absolute;
		left: 0;
		top: 0.2rem; /* Visual nudge to perfectly center with text baseline */
		width: 2.5rem;
		text-align: right;
		content: "0x0" counter(toc-counter);
		color: var(--text-dim);
		font-family: "Share Tech Mono", monospace;
		font-size: 0.75rem;
		letter-spacing: 0.1em;
		transition: all 0.2s ease;
		opacity: 0.6;
	}

	.article-content > ul:first-of-type li:hover::before {
		content: "->";
		color: var(--accent);
		opacity: 1;
	}

	.article-content > ul:first-of-type a {
		text-transform: uppercase;
		font-size: 0.95rem;
		border-bottom: none !important;
		color: var(--text-body);
		transition: all 0.2s ease;
		display: inline-block;
	}

	.article-content > ul:first-of-type a:hover {
		color: var(--accent);
	}

	.blog-article-wrapper {
		padding-top: 6rem;
		padding-bottom: 5rem;
	}
	.blog-container {
		max-width: 56rem;
		margin: 0 auto;
		padding: 0 1rem;
	}
	.terminal-body {
		padding: 1.5em;
	}
	.blog-cover-wrapper {
		background-color: rgba(0, 0, 0, 0.4);
	}
	.blog-cover-image {
		width: 100%;
		height: auto;
		max-height: 500px;
		object-fit: contain;
	}
	.blog-article-content {
		padding-left: 1rem;
		padding-right: 1rem;
		padding-bottom: 3rem;
	}
</style>
