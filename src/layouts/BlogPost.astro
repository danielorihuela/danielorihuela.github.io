---
import { Image } from "astro:assets";
import FileHeader from "../components/FileHeader.astro";
import BaseLayout from "./BaseLayout.astro";
import Panel from "../components/Panel.astro";
import "../styles/code-snippet.css";
import "../styles/inline-code.css";
import "../styles/toc.css";
import "../styles/article-headings.css";

interface Props {
	title: string;
	description: string;
	publishdate: Date;
	cover: any;
	slug: string;
	contentLength: number;
}

const { title, description, publishdate, cover, slug, contentLength } =
	Astro.props;
---

<BaseLayout title={title} description={description} image={cover?.src}>
	<article class="blog-article-wrapper">
		<div class="blog-container">
			<Panel>
				<FileHeader
					publishdate={publishdate}
					contentLength={contentLength}
				/>

				<div class="terminal-body">
					<h1 class="post-article-title">
						{title}
					</h1>

					{
						cover && (
							<Image
								class="blog-cover-image"
								src={cover}
								alt=""
								quality={100}
							/>
						)
					}

					<div class="article-content">
						<slot />
					</div>
				</div>
			</Panel>
		</div>
	</article>
</BaseLayout>

<style is:global>
	.blog-article-wrapper {
		padding-top: 6rem;
		padding-bottom: 5rem;
	}

	.blog-container {
		max-width: 56rem;
		margin: 0 auto;
		padding: 0 1rem;
	}

	.terminal-body {
		padding: 1.5em;
	}

	.post-article-title {
		font-size: 1.8em;
		margin-bottom: 1.5rem;
	}

	@media (min-width: 640px) {
		.post-article-title {
			font-size: 2.5em;
		}
	}

	.blog-cover-image {
		background-color: rgba(0, 0, 0, 0.4);
		width: 100%;
		height: auto;
		max-height: 500px;
		object-fit: contain;
	}

	.article-content {
		padding-left: 1rem;
		padding-right: 1rem;
		padding-bottom: 3rem;
	}

	.article-content img {
		display: flex;
		max-width: 100%;
		height: auto;
		margin: 0 auto;
		border: 1px solid var(--border);
		box-shadow: 0 0 20px rgba(0, 0, 0, 0.4);
	}

	.article-content p {
		color: var(--text-body);
		line-height: 1.8;
		margin-bottom: 1.5em;
	}

	.article-content a {
		color: var(--accent);
		text-decoration: none;
		border-bottom: 1px solid rgba(0, 212, 255, 0.2);
		transition: all 0.2s ease;
	}

	.article-content a:hover {
		color: #fff;
		border-bottom-color: var(--accent);
		text-shadow: 0 0 8px var(--accent-glow);
	}

	.article-content blockquote {
		border-left: 3px solid var(--accent);
		padding: 0.5em 0 0.5em 1.5em;
		margin: 1.5em 0;
		background: rgba(0, 212, 255, 0.03);
		color: var(--text-dim);
		font-style: italic;
	}

	.article-content table {
		width: 100%;
		table-layout: fixed;
		border-collapse: collapse;
	}

	.article-content table,
	.article-content th,
	.article-content td {
		border: 1px solid var(--border);
	}

	.article-content th {
		background: var(--accent-extra-dim);
		color: var(--accent);
		font-family: "Share Tech Mono", monospace;
		text-transform: uppercase;
		padding: 0.75em;
	}

	.article-content td {
		padding: 0.75em;
	}
</style>
