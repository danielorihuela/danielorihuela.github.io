---
import { Image } from "astro:assets";
import BaseLayout from "./BaseLayout.astro";
import Panel from "../components/Panel.astro";
import "../styles/code-snippet.css";
import "../styles/inline-code.css";
import "../styles/toc.css";
import "../styles/post-headings.css";

interface Props {
	title: string;
	description: string;
	publishdate: Date;
	cover: any;
	slug: string;
	contentLength: number;
}

const { title, description, publishdate, cover, slug, contentLength } =
	Astro.props;

const formattedDate = publishdate.toISOString().split("T")[0];
const fileSize = (contentLength / 1024).toFixed(1) + " KB";

const metadata = [
	{ label: "DATE", value: formattedDate },
	{ label: "| SIZE", value: fileSize },
	{ label: "| LINES", value: "AUTO" },
	{ label: "| ENCODING", value: "UTF-8" },
];
---

<BaseLayout title={title} description={description} image={cover?.src}>
	<article>
		<div class="post-wrapper">
			<Panel>
				<div class="post-metadata">
					<div>
						{
							metadata.map((item) => (
								<span class="metadata-item">
									{item.label}:
									<span class="metadata-value">
										{item.value}
									</span>
								</span>
							))
						}
					</div>
				</div>

				<div class="post-content-wrapper">
					<h1 class="post-title">
						{title}
					</h1>

					{
						cover && (
							<Image
								class="post-image"
								src={cover}
								alt=""
								quality={100}
							/>
						)
					}

					<div class="post-content">
						<slot />
					</div>
				</div>
			</Panel>
		</div>
	</article>
</BaseLayout>

<style is:global>
	article {
		padding-top: 6rem;
		padding-bottom: 5rem;
	}

	.post-wrapper {
		max-width: 56rem;
		margin: 0 auto;

		@media (min-width: 640px) {
			padding: 0 1rem;
		}
	}

	.post-metadata {
		display: flex;
		justify-content: space-between;
		background-color: var(--accent-extra-dim);
		padding: 0.5rem 1rem;
		font-family: "Share Tech Mono", monospace;
		font-size: 0.75rem;

		&::before {
			content: "●";
			color: var(--accent);
		}
	}

	.metadata-item {
		display: none;

		&:nth-child(-n + 2) {
			display: inline;
		}

		@media (min-width: 640px) {
			display: inline;
		}
	}

	.metadata-value {
		color: var(--accent);
	}

	.post-content-wrapper {
		padding: 0.75em;

		@media (min-width: 640px) {
			padding: 1.5em;
		}
	}

	.post-title {
		font-size: 1.8em;
		margin-bottom: 1.5rem;

		@media (min-width: 640px) {
			font-size: 2.5em;
		}
	}

	.post-image {
		background-color: rgba(0, 0, 0, 0.4);
		width: 100%;
		height: auto;
		max-height: 500px;
		object-fit: contain;
	}

	.post-content {
		padding-left: 1rem;
		padding-right: 1rem;
		padding-bottom: 3rem;
	}

	.post-content img {
		display: flex;
		max-width: 100%;
		height: auto;
		margin: 0 auto;
		border: 1px solid var(--border);
		box-shadow: 0 0 20px rgba(0, 0, 0, 0.4);
	}

	.post-content p {
		color: var(--text-body);
		line-height: 1.8;
		margin-bottom: 1.5em;
	}

	.post-content a {
		color: var(--accent);
		text-decoration: none;
		transition: all 0.2s ease;
	}

	.post-content a:hover {
		color: #fff;
		text-shadow: 0 0 8px var(--accent-glow);
	}

	.post-content blockquote {
		border-left: 3px solid var(--accent);
		padding: 0.5em 0 0.5em 1.5em;
		margin: 1.5em 0;
		background: rgba(0, 212, 255, 0.03);
		color: var(--text-dim);
		font-style: italic;
	}

	.post-content table {
		width: 100%;
		table-layout: fixed;
		border-collapse: collapse;
		margin-bottom: 1.5em;
	}

	.post-content table,
	.post-content th,
	.post-content td {
		border: 1px solid var(--border);
		overflow-wrap: break-word;
	}

	.post-content th {
		background: var(--accent-extra-dim);
		color: var(--accent);
		font-family: "Share Tech Mono", monospace;
		text-transform: uppercase;
		padding: 0.75em;
	}

	.post-content td {
		padding: 0.75em;
	}
</style>
