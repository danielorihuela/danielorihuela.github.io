---
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import SocialLink from "../components/SocialLink.astro";

const contactLinks = [
	["https://github.com/danielorihuela", "/github.svg", "Github"],
	["mailto:danielorihuelarodriguez@gmail.com", "/email.svg", "Email"],
];
---

<html lang="en">
	<head>
		<BaseHead title="About Me" description="Software engineer specializing in cybersecurity, cryptography, and distributed systems." />
	</head>

	<body class="bg-cyber-black min-h-screen flex flex-col">
		<Header />
		<main class="flex-1 pt-20 pb-16">
			<div class="max-w-3xl mx-auto px-4 lg:px-6">
				{/* Terminal header */}
				<div class="font-display text-sm text-terminal-dim mb-8 mt-8">
					<span class="text-accent">$</span> cat profile.txt
				</div>

				{/* Identity block */}
				<div class="terminal-window mb-6">
					<div class="terminal-header">
						daniel — identity
					</div>
					<div class="terminal-body">
						<h1 class="text-3xl md:text-4xl font-display mb-2">
							Daniel <span class="text-accent">Orihuela</span>
						</h1>
						<p class="text-terminal-dim text-sm font-display mt-0">
							Software Engineer · Security Researcher · Open Source Contributor
						</p>
					</div>
				</div>

				{/* About block */}
				<div class="terminal-window mb-6">
					<div class="terminal-header">
						about.md
					</div>
					<div class="terminal-body space-y-4 text-terminal-text leading-relaxed">
						<p>
							I'm a dedicated Software Engineer with a deep-rooted passion
							for Cybersecurity, Cryptography, Algorithms, Distributed Systems,
							and AI. Over the past five years, I have honed my expertise within
							the fintech and security sectors, designing and developing robust,
							scalable solutions that prioritize security and efficiency.
						</p>
						<p>
							A relentless problem solver and aspiring hacker, I thrive on challenges that push
							the boundaries of secure systems and innovation.
						</p>
					</div>
				</div>

				{/* Skills grid */}
				<div class="grid md:grid-cols-2 gap-4 mb-6">
					<div class="terminal-window">
						<div class="terminal-header">
							expertise.log
						</div>
						<div class="terminal-body">
							<ul class="space-y-1 text-sm text-terminal-text p-0">
								<li>Backend Engineering</li>
								<li>Cryptographic Libraries</li>
								<li>Software Architecture</li>
								<li>Developer Tooling</li>
								<li>Privacy-first Systems</li>
							</ul>
						</div>
					</div>

					<div class="terminal-window">
						<div class="terminal-header">
							philosophy.log
						</div>
						<div class="terminal-body text-sm text-terminal-text">
							<p class="mt-0">
								Security and scalability should never be a second thought.
								I build systems with resilience and privacy in mind, ensuring
								they are both secure and scalable from the ground up.
							</p>
							<p>
								I strive to design solutions that are efficient, maintainable,
								and future-proof.
							</p>
						</div>
					</div>
				</div>

				{/* Contact */}
				<div class="terminal-window">
					<div class="terminal-header">
						contact — links
					</div>
					<div class="terminal-body">
						<div class="flex items-center gap-4">
							{contactLinks.map(([href, image]) => (
								<SocialLink
									class="w-10 h-10"
									href={href}
									image={image}
								/>
							))}
						</div>
					</div>
				</div>
			</div>
		</main>
		<Footer />
	</body>
</html>
