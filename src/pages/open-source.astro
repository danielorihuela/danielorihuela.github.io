		url: "https://github.com/newrelic/newrelic-agent-control",
		description:
			"Agent Control is a lightweight agent supervisor that runs on Kubernetes clusters and hosts to manage the lifecycle of New Relic and open-source instrumentation agents. Communicating with Fleet Control, it remotely configures, updates, and monitors agent health across fleets.",
		stack: "RUST",
		time: {
			start: 2025,
			end: 2026,
		},
		contributions: "100+",
		prs: [
			{
				id: 2527,
				title: "feat: memory growth alert",
			},
			{
				id: 2448,
				title: "feat: global registry support",
			},
			{
				id: 2368,
				title: "feat: integrate dry-run checks with executor",
			},
			{
				id: 2294,
				title: "feat: connectivity check",
			},
			{
				id: 1956,
				title: "feat: generic opamp attributes reporter",
			},
			{
				id: 1384,
				title: "fix: onhost infra provision",
			},
			{
				id: 1325,
				title: "feat: add patch to k8s client",
			},
			{
				id: 1283,
				title: "feat: create ac resources with cli",
			},
			{
				id: 1040,
				title: "Feat/shutdown health checker gracefully",
			},
			{
				id: 1035,
				title: "feat: named threads",
			},
		],
	},
	{
		name: "SyMPC",
		image: "/open-mined.svg",
		url: "https://github.com/OpenMined/SyMPC",
		description:
			"A SMPC library for PySyft to perform computations on encrypted data without decrypting it.",
		stack: "PYTHON",
		time: {
			start: 2021,
			end: 2021,
		},
		contributions: "10+",
		prs: [
			{ id: 281, title: "docs: protocol table" },
			{ id: 253, title: "Feat/ci scheduled tests" },
			{
				id: 216,
				title: "Feat/duet in docker container",
			},
			{ id: 195, title: "docs: readme" },
			{ id: 170, title: "fix: add lacking methods" },
			{
				id: 162,
				title: "feat: move allowlist from syft to sympc",
			},
			{
				id: 132,
				title: "Style/flake8 configuration",
			},
			{
				id: 130,
				title: "fix: benchmark output file path",
			},
			{
				id: 128,
				title: "feat/benchmark convolutional network",
			},
			{
				id: 114,
				title: "test: parametrize reciprocal",
			},
		],
	},
	{
		name: "sycret",
		image: "/open-mined.svg",
		url: "https://github.com/OpenMined/sycret",
		description:
			"A Rust-based library for Function Secret Sharing, providing high performance for private computations.",
		stack: "RUST",
		time: {
			start: 2021,
			end: 2021,
		},
		contributions: "4",
		prs: [
			{
				id: 36,
				title: "Refactor/solve clippy warnings",
			},
			{
				id: 25,
				title: "fix: python automated tests",
			},
