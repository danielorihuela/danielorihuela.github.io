		],
	},
	{
		name: "PySyft",
		image: "/open-mined.svg",
		url: "https://github.com/OpenMined/PySyft",
		description:
			"A library for secure and private Distributed AI. PySyft decouples private data from model training.",
		stack: "PYTHON / TENSOR",
		time: {
			start: 2021,
			end: 2021,
		},
		contributions: "1",
		prs: [
			{
				id: 5554,
				title: "feat: move allowlist from syft to sympc",
			},
		],
	},
	{
		name: "Gitleaks",
		image: "/gitleaks.svg",
		url: "https://github.com/gitleaks/gitleaks",
		description:
			"SAST tool for detecting and preventing hardcoded secrets like passwords, api keys, and tokens in git repos.",
		stack: "GO",
		time: {
			start: 2021,
			end: 2021,
		},
		contributions: "1",
		prs: [{ id: 661, title: "fix: csv report in excel" }],
	},
	{
		name: "Lynis",
		image: "/lynis.svg",
		url: "https://github.com/CISOfy/lynis",
		description:
			"Security auditing tool for Linux, macOS, and Unix-based systems. Assists with compliance testing and hardening.",
		stack: "BASH",
		time: {
			start: 2020,
			end: 2020,
		},
		contributions: "1",
		prs: [
			{
				id: 1009,
				title: "[AUTH-9284] Feature: gather locked accounts info",
			},
		],
	},
];

ossProjectsInfo.forEach((project) => {
	project.prs.sort((a, b) => b.id - a.id);
});
ossProjectsInfo.sort((a, b) => b.time.end - a.time.end);

const projectsMetadata = ossProjectsInfo.map((project, idx) => [
	["ID_REF", `0x${(0x7f4c0000 + idx * 0x10).toString(16).toUpperCase()}`],
	["CONTRIB_PERIOD", `${project.time.start} — ${project.time.end}`],
	["PR_CONTRIB", project.contributions],
	["BASE_STACK", project.stack],
]);
---

<BaseLayout
	title="Open Source"
	description="Open source contributions to security and privacy tools."
>
	<main>
		<div class="list">
			{
				ossProjectsInfo.map(
					({ name, image, url, description, prs }, idx) => (
						<Panel class="card group">
							<div class="sidebar">
								{projectsMetadata[idx].map(([label, value]) => (
									<div class="metadata-item">
										<span class="metadata-label">
											{label}
										</span>
										<span class="metadata-value">
											{value}
										</span>
									</div>
								))}
							</div>

							<div class="content">
								<div class="header">
									<a
										href={url}
										class="social-link icon"
										target="_blank"
										rel="noopener noreferrer"
									>
										<img
											class="social-link-img"
											src={image}
											alt=""
										/>
									</a>

									<span class="title">{name} </span>
								</div>

								<p class="description">{description}</p>

								<div class="pr-log-section">
									<div class="pr-log-header">
										:: CONTRIBUTIONS
									</div>
									{prs.map((pr) => (
										<LinkEntry
											href={`${url}/pull/${pr.id}`}
											external
											indicator="VIEW_PR"
											class="pr-link"
										>
											<span class="pr-id">
												PR #{pr.id}
											</span>
											<span class="pr-title">
												{pr.title}
											</span>
										</LinkEntry>
									))}
									<LinkEntry
										href={`${url}/pulls?q=is%3Apr+author%3Adanielorihuela`}
										external
										indicator="GO_TO_REPO"
										class="pr-link view-all-link"
									>
										<span class="pr-id">ALL PRs</span>
										<span class="pr-title">
											View all contributions
										</span>
									</LinkEntry>
								</div>
							</div>
						</Panel>
					),
				)
			}
		</div>
	</main>
</BaseLayout>

<style>
	main {
		padding-top: 5rem;
		padding-bottom: 4rem;
		max-width: 56rem;
		margin-left: auto;
		margin-right: auto;
		padding-left: 1rem;
		padding-right: 1rem;
	}

	.list {
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
	}

	.card {
		display: flex;
		flex-direction: column;
		transition: all 0.3s ease;

		@media (min-width: 640px) {
			flex-direction: row;
		}
	}

	.sidebar {
		flex-shrink: 0;
		background-color: rgba(255, 255, 255, 0.02);
		padding: 1rem;
		display: flex;
		gap: 1rem 1.5rem;
		border-bottom: 1px solid rgba(28, 32, 53, 0.1);

		@media (min-width: 640px) {
			flex-direction: column;
			gap: 1.25rem;
		}
	}

	.metadata-item {
		display: flex;
		flex-direction: column;
		gap: 0.375rem;

		&:first-child {
			display: none;

			@media (min-width: 640px) {
				display: flex;
			}
		}
	}

	.metadata-label {
		font-size: 0.75rem;
		letter-spacing: 0.05em;
		opacity: 0.6;
		font-weight: 700;
	}

	.metadata-value {
		font-size: 0.875rem;
		font-family: "Share Tech Mono", monospace;
	}

	.content {
		display: flex;
		flex-direction: column;
		gap: 1rem;
		padding: 1.5rem;
	}

	.header {
		display: flex;
		align-items: center;
		gap: 1rem;
	}

	.social-link {
		display: flex;
		overflow: hidden;
		border-radius: 6px;
		border: 1px solid var(--border);
		background: var(--bg-panel);
		padding: 0.4em;
		transition:
			border-color 0.3s ease,
			filter 0.3s ease;
		filter: brightness(1);

		&:hover {
			border-color: var(--accent);
		}

		&::before {
			content: "";
			position: absolute;
			left: 0;
			top: -2px;
			width: 100%;
			height: 2px;
			background: linear-gradient(
				90deg,
				transparent,
				var(--accent),
				transparent
			);
		}

		&:hover::before {
			animation: sweepLine 2s ease-in-out infinite;
		}
	}

	.social-link-img {
		filter: grayscale(100%) brightness(0.7);
		transition: filter 0.3s ease;

		&:hover {
			filter: grayscale(0%) brightness(1);
		}
	}

	@keyframes sweepLine {
		0% {
			top: -2px;
		}
		100% {
			top: 100%;
		}
	}

	.icon {
		width: 3rem;
		height: 3rem;
	}

	.title {
		font-size: 1.5rem;
		color: var(--text-bright);
	}

	.description {
		font-size: 0.875rem;
		line-height: 1.625;
		margin: 0;
	}

	.pr-log-section {
		padding-top: 1rem;
	}

	.pr-log-header {
		margin-bottom: 0.75rem;
		font-size: 0.75rem;
		letter-spacing: 0.05em;
		color: var(--accent);
	}

	.pr-link {
		gap: 0.75rem;
		font-size: 0.875rem;
		padding: 0.125rem 0.5rem;
	}

	.pr-id {
		font-family: "Share Tech Mono", monospace;
		flex-shrink: 0;
	}

	.pr-title {
		color: var(--text-bright);
		transition: color 0.3s ease;
	}

	.view-all-link {
		margin-top: 0.5rem;
	}

	.view-all-link .pr-id {
		color: var(--accent);
		opacity: 0.8;
	}

	.view-all-link .pr-title {
		color: var(--text-body);
		font-style: italic;
	}
</style>
