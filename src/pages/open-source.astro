---
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import SocialLink from "../components/SocialLink.astro";

interface PrInfo {
	id: number;
	title?: string;
}

interface OssProjectInfo {
	name: string;
	description: string;
	image: string;
	url: string;
	prs: PrInfo[];
	stack: string;
}

const ossProjectsInfo: OssProjectInfo[] = [
	{
		name: "Lynis",
		image: "/lynis.svg",
		url: "https://github.com/CISOfy/lynis",
		description: "Security auditing tool for Linux, macOS, and Unix-based systems. Assists with compliance testing and hardening.",
		stack: "BASH",
		prs: [
			{ id: 1009, title: "fix: shell completion for bash" },
			{ id: 1010, title: "feat: add support for new distro" }
		]
	},
	{
		name: "Gitleaks",
		image: "/gitleaks.svg",
		url: "https://github.com/gitleaks/gitleaks",
		description: "SAST tool for detecting and preventing hardcoded secrets like passwords, api keys, and tokens in git repos.",
		stack: "GO",
		prs: [
			{ id: 661, title: "fix: avoid false positives in .env files" }
		]
	},
	{
		name: "PySyft",
		image: "/open-mined.svg",
		url: "https://github.com/OpenMined/PySyft",
		description: "A library for secure and private Distributed AI. PySyft decouples private data from model training.",
		stack: "PYTHON / TENSOR",
		prs: [
			{ id: 5553, title: "feat: integration with new storage backend" },
		]
	},
	{
		name: "sycret",
		image: "/open-mined.svg",
		url: "https://github.com/OpenMined/sycret",
		description: "A Rust-based library for Function Secret Sharing, providing high performance for private computations.",
		stack: "RUST",
		prs: [
			{ id: 17, title: "perf: optimize bitwise operations in Rust" },
			{ id: 18, title: "perf: optimize bitwise operations in Rust" },
			{ id: 25, title: "perf: optimize bitwise operations in Rust" },
			{ id: 36, title: "perf: optimize bitwise operations in Rust" }
		]
	},
	{
		name: "SyMPC",
		image: "/open-mined.svg",
		url: "https://github.com/OpenMined/SyMPC",
		description: "A SMPC library for PySyft to perform computations on encrypted data without decrypting it.",
		stack: "PYTHON",
		prs: [
			{ id: 114 },
			{ id: 128 },
			{ id: 130 },
			{ id: 132 },
			{ id: 162 },
			{ id: 170 },
			{ id: 174 },
			{ id: 195 },
			{ id: 216 },
			{ id: 253 },
			{ id: 281 }
		]
	}
];

---

<html lang="en">
	<head>
		<BaseHead title="Open Source" description="Open source contributions to security and privacy tools." />
	</head>

	<body class="bg-cyber-black min-h-screen flex flex-col">
		<Header />
		<main class="flex-1 pt-20 pb-16">
			<div class="max-w-4xl mx-auto px-4 lg:px-6">
				{/* Terminal header - Clean Command Prompt */}
				<div class="font-display text-xs md:text-sm mb-8 mt-8 border-b border-cyber-border pb-4 flex items-center gap-2">
					<span class="text-accent font-bold">$</span>
					<span class="text-terminal-bright">cat ./contributions/*</span>
				</div>

				{/* Wide Dashboard Cards */}
				<div class="flex flex-col gap-6">
					{ossProjectsInfo.map((info, idx) => {
						return (
							<div class="terminal-window group flex flex-col sm:flex-row hover:border-accent/40 hover:bg-accent/[0.02] transition-all duration-300 overflow-hidden">
								{/* Left Metadata Sidebar */}
								<div class="sm:w-32 shrink-0 bg-white/[0.02] p-4 flex flex-wrap sm:flex-col justify-start gap-x-6 gap-y-4 sm:gap-5 border-b sm:border-b-0 sm:border-r border-cyber-border/10">
									<div class="flex flex-col gap-1.5">
										<span class="text-xs uppercase tracking-wider text-terminal-text opacity-60 font-bold">ID_REF</span>
										<span class="text-sm font-mono text-terminal-bright">0x{(0x7f4c0000 + idx * 0x10).toString(16).toUpperCase()}</span>
									</div>
									<div class="flex flex-col gap-1.5">
										<span class="text-xs uppercase tracking-wider text-terminal-text opacity-60 font-bold">PR_CONTRIB</span>
										<span class="text-sm font-mono text-terminal-bright">#{info.prs.length.toString().padStart(2, '0')}</span>
									</div>
									<div class="flex flex-col gap-1.5">
										<span class="text-xs uppercase tracking-wider text-terminal-text opacity-60 font-bold">BASE_STACK</span>
										<span class="text-sm font-mono text-terminal-bright">{info.stack}</span>
									</div>
								</div>

								{/* Main Content Area */}
								<div class="flex-1 p-6 flex flex-col gap-4">
									<div class="flex items-center gap-4">
										<SocialLink
											class="w-12 h-12 shrink-0 transition-transform duration-300 brightness-90 group-hover:brightness-110"
											href={info.url}
											image={info.image}
										/>
										<div class="min-w-0">
											<a
												href={info.url}
												class="font-display text-2xl text-terminal-bright group-hover:text-white transition-colors duration-200 truncate"
												target="_blank"
												rel="noopener noreferrer"
											>
												{info.name}
											</a>
										</div>
									</div>

									<p class="text-terminal-text text-sm leading-relaxed max-w-2xl">
										{info.description}
									</p>

									{/* PR Log Section */}
									<div class="pt-4 border-t border-cyber-border/10">
										<div class="flex items-center gap-2 mb-3">
											<span class="text-xs uppercase tracking-wider text-accent font-bold">:: PULL_REQUEST_LOG</span>
										</div>
										<div class="flex flex-col gap-1">
											{info.prs.map((pr) => (
												<a
													href={`${info.url}/pull/${pr.id}`}
													class="group/pr flex items-start gap-3 text-sm px-3 py-2 border-l-2 border-transparent hover:border-accent hover:bg-gradient-to-r hover:from-accent/10 hover:to-transparent text-terminal-text transition-all duration-300 hover:translate-x-1 uppercase"
													target="_blank"
													rel="noopener noreferrer"
												>
													<span class="text-accent group-hover/pr:scale-110 transition-transform duration-300 font-bold mt-0.5">{'>'}</span>
													<span class="text-terminal-bright font-mono min-w-[64px] group-hover/pr:text-white transition-colors duration-300 mt-0.5">PR #{pr.id}</span>
													<span class="text-terminal-text group-hover/pr:text-terminal-bright transition-colors duration-300 font-medium tracking-tight leading-snug flex-1">
														{pr.title || "Unlogged contribution..."}
													</span>
												</a>
											))}
										</div>
									</div>
								</div>
							</div>
						);
					})}
				</div>
			</div>
		</main>
		<Footer />
	</body>
</html>
