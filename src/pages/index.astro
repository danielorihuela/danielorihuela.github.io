---
import { SITE_TITLE, SITE_DESCRIPTION } from "../consts";
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import Command from "../components/Command.astro";

const posts = (await getCollection("blog")).sort(
	(a, b) =>
		b.data.publishdate.valueOf() - a.data.publishdate.valueOf() ||
		b.id.localeCompare(a.id),
);

// FNV-1a variant
function hash(str: string) {
	let hash = 2166136261;
	for (let i = 0; i < str.length; i++) {
		hash ^= str.charCodeAt(i);
		hash = Math.imul(hash, 16777619);
	}
	return (hash >>> 0).toString(16).padStart(7, "0").slice(0, 7);
}

function formatDate(date: Date) {
	return date.toISOString().split("T")[0].replaceAll("-", ".");
}
---

<BaseLayout title={SITE_TITLE} description={SITE_DESCRIPTION}>
	<main>
		<Command command='find ./blog -maxdepth 1 -name "*.md" -type f' />

		{
			posts.map((post) => {
				return (
					<a href={`/blog/${post.id}/`} class="group blog-post-link">
						<div class="metadata-column">
							<span>{formatDate(post.data.publishdate)}</span>
							<span>[rev:{hash(post.id)}]</span>
						</div>

						<div class="title-column">
							<span class="title-symbol">&gt;</span>
							<h2 class="title-text">{post.data.title}</h2>
						</div>

						<span class="indicator-text">READ_ENTRY</span>
					</a>
				);
			})
		}
	</main>
</BaseLayout>

<style>
	main {
		padding-top: 5rem;
		padding-bottom: 4rem;
		max-width: 56rem;
		margin: 0 auto;
		font-family: "Share Tech Mono", monospace;
	}

	.blog-post-link {
		display: flex;
		flex-direction: column;
		margin-top: 0.25rem;
		gap: 0.5rem;
		padding: 0.75rem 1rem;
		border-left: 2px solid transparent;
		transition: all 300ms;
	}

	@media (min-width: 640px) {
		.blog-post-link {
			flex-direction: row;
			gap: 1.5rem;
		}
	}

	.blog-post-link:hover {
		border-left-color: var(--accent);
		background-image: linear-gradient(
			to right,
			rgba(0, 212, 255, 0.1),
			transparent
		);
		transform: translateX(0.25rem);
	}

	.metadata-column {
		display: flex;
		align-items: center;

		gap: 1rem;

		font-size: 0.75rem;
		font-family: "Liberation Mono", monospace;

		color: var(--text-body);
		opacity: 0.7;
	}

	.title-column {
		display: flex;
		align-items: center;
		gap: 0.5rem;
	}

	.title-symbol {
		display: none;
	}

	.title-text {
		font-size: 0.875rem;
		margin: 0;
	}

	@media (min-width: 640px) {
		.title-symbol {
			display: block;
			transition: transform 300ms;
		}

		.title-text {
			font-size: 1rem;
		}
	}

	.indicator-text {
		display: none;
		opacity: 0;
		margin-left: auto;

		font-size: 0.65rem;
		color: var(--text-body);
		transition: all 300ms;
		letter-spacing: 0.1em;
	}

	@media (min-width: 640px) {
		.indicator-text {
			display: block;
			align-self: center;
		}

		.group:hover .indicator-text {
			opacity: 0.6;
		}
	}
</style>
