---
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import Metadata from "../components/blog-list-item/Metadata.astro";
import Title from "../components/blog-list-item/Title.astro";
import Indicator from "../components/blog-list-item/Indicator.astro";
import { SITE_TITLE, SITE_DESCRIPTION } from "../consts";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog")).sort((a, b) => {
	const dateDiff =
		b.data.publishdate.valueOf() - a.data.publishdate.valueOf();
	if (dateDiff !== 0) return dateDiff;
	return b.id.localeCompare(a.id);
});
---

<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body class="index-body">
		<Header />
		<main class="main-content content-container">
			<div class="terminal-header-bar">
				<span class="terminal-prompt">$</span>
				<span class="terminal-command"
					>find ./blog -maxdepth 1 -name "*.md" -type f</span
				>
			</div>

			<div class="blog-list">
				{
					posts.map((post) => {
						return (
							<a
								href={`/blog/${post.id}/`}
								class="group blog-post-link"
							>
								<Metadata
									slug={post.id}
									date={post.data.publishdate}
								/>

								<Title title={post.data.title} />

								<div class="indicator-wrapper">
									<Indicator />
								</div>
							</a>
						);
					})
				}
			</div>
		</main>
		<Footer />
	</body>
</html>

<style>
	.index-body {
		min-height: 100vh;
	}

	.main-content {
		padding-top: 5rem;
		padding-bottom: 4rem;
		max-width: 56rem;
		margin: 0 auto;
	}

	.terminal-header-bar {
		font-family: "Share Tech Mono", monospace;
		font-size: 0.75rem;
		margin: 1rem 0;
		border-bottom: 1px solid #1c2035;
		padding-bottom: 1rem;
	}

	@media (min-width: 768px) {
		.terminal-header-bar {
			font-size: 0.875rem;
		}
	}

	.terminal-prompt {
		color: #00d4ff;
		font-weight: bold;
	}

	.terminal-command {
		color: #e0e6ed;
		font-weight: bold;
	}

	.blog-list > * + * {
		margin-top: 0.25rem;
	}

	.blog-post-link {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
		padding: 0.75rem 1rem;
		border-left: 2px solid transparent;
		transition: all 300ms;
		text-decoration: none;
	}

	@media (min-width: 640px) {
		.blog-post-link {
			flex-direction: row;
			gap: 1.5rem;
		}
	}

	.blog-post-link:hover {
		border-left-color: #00d4ff;
		background-image: linear-gradient(
			to right,
			rgba(0, 212, 255, 0.1),
			transparent
		);
		transform: translateX(0.25rem);
	}

	.indicator-wrapper {
		display: none;
		opacity: 0;
		transition: opacity 300ms;
	}

	@media (min-width: 768px) {
		.indicator-wrapper {
			display: block;
		}

		.group:hover .indicator-wrapper {
			opacity: 0.6;
		}
	}
</style>
