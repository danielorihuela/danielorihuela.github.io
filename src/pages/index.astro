---
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import Metadata from "../components/blog-list-item/Metadata.astro";
import Title from "../components/blog-list-item/Title.astro";
import Indicator from "../components/blog-list-item/Indicator.astro";
import { SITE_TITLE, SITE_DESCRIPTION } from "../consts";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog")).sort((a, b) => {
	const dateDiff =
		b.data.publishdate.valueOf() - a.data.publishdate.valueOf();
	if (dateDiff !== 0) return dateDiff;
	return b.slug.localeCompare(a.slug);
});
---

<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body class="bg-cyber-black min-h-screen flex flex-col">
		<Header />
		<main class="flex-1 pt-20 pb-16">
			<div class="max-w-4xl mx-auto px-4 lg:px-6">
				{/* Terminal header - Clean Command Prompt */}
				<div
					class="font-display text-xs md:text-sm mb-8 mt-8 border-b border-cyber-border pb-4 flex items-center gap-2"
				>
					<span class="text-accent font-bold">$</span>
					<span class="text-terminal-bright font-bold"
						>find ./blog -maxdepth 1 -name "*.md" -type f</span
					>
				</div>

				{/* Polished Hacker Blog List */}
				<div class="flex flex-col space-y-1">
					{
						posts.map((post) => {
							return (
								<a
									href={`/blog/${post.slug}/`}
									class="group flex flex-col sm:flex-row sm:items-baseline gap-2 sm:gap-6 px-4 py-3 border-l-2 border-transparent hover:border-accent hover:bg-gradient-to-r hover:from-accent/10 hover:to-transparent transition-all duration-300 hover:translate-x-1"
								>
									<Metadata
										slug={post.slug}
										date={post.data.publishdate}
									/>

									<Title title={post.data.title} />

									<div class="indicator-wrapper">
										<Indicator />
									</div>
								</a>
							);
						})
					}
				</div>
			</div>
		</main>
		<Footer />
	</body>
</html>

<style>
	.indicator-wrapper {
		display: none;
		opacity: 0;
		transition: opacity 300ms;
	}

	@media (min-width: 768px) {
		.indicator-wrapper {
			display: block;
		}

		.group:hover .indicator-wrapper {
			opacity: 0.6;
		}
	}
</style>
