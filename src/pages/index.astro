---
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { SITE_TITLE, SITE_DESCRIPTION } from "../consts";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog")).sort((a, b) => {
	const dateDiff = b.data.publishdate.valueOf() - a.data.publishdate.valueOf();
	if (dateDiff !== 0) return dateDiff;
	return b.slug.localeCompare(a.slug);
});

// Improved high-entropy hash (FNV-1a variant) for unique fixed-length identifiers
function getShortHash(str: string) {
	let hash = 2166136261;
	for (let i = 0; i < str.length; i++) {
		hash ^= str.charCodeAt(i);
		hash = Math.imul(hash, 16777619);
	}
	return (hash >>> 0).toString(16).padStart(7, '0').slice(0, 7);
}

function formatDateTechnical(date: Date) {
	return date.toISOString().split('T')[0].replaceAll('-', '.');
}
---

<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body class="bg-cyber-black min-h-screen flex flex-col">
		<Header />
		<main class="flex-1 pt-20 pb-16">
			<div class="max-w-4xl mx-auto px-4 lg:px-6">
				{/* Terminal header - Clean Command Prompt */}
				<div class="font-display text-xs md:text-sm mb-8 mt-8 border-b border-cyber-border pb-4 flex items-center gap-2">
					<span class="text-accent font-bold">$</span>
					<span class="text-terminal-bright font-bold">find ./blog -maxdepth 1 -name "*.md" -type f</span>
				</div>

				{/* Polished Hacker Blog List */}
				<div class="flex flex-col space-y-1">
					{posts.map((post) => {
						const hash = getShortHash(post.slug);
						const formattedDate = formatDateTechnical(post.data.publishdate);
						
						return (
							<a
								href={`/blog/${post.slug}/`}
								class="group flex flex-col sm:flex-row sm:items-baseline gap-2 sm:gap-6 px-4 py-3 border border-transparent hover:border-accent/20 hover:bg-accent/5 transition-all duration-150 rounded"
							>
								{/* Meta Data Column */}
								<div class="flex items-center gap-4 text-xs font-display flex-shrink-0">
									<span class="text-terminal-dim font-bold tracking-tight">
									{formattedDate}
								</span>
									<span class="text-terminal-dim font-mono hidden md:inline brightness-125">
									[rev:<span class="text-cyan font-bold">{hash}</span>]
								</span>
								</div>

								{/* Title Column */}
								<div class="flex-1 min-w-0 flex items-center gap-2">
									<span class="text-accent opacity-0 group-hover:opacity-100 transition-opacity duration-150 hidden sm:inline -ml-4">
										&gt;
									</span>
									<h2 class="text-sm md:text-base font-display text-terminal-bright group-hover:text-white transition-colors duration-150 m-0 truncate">
										{post.data.title}
									</h2>
								</div>

								{/* Interaction Indicator */}
								<div class="hidden md:block">
									<span class="text-[10px] font-display text-terminal-dim opacity-0 group-hover:opacity-100 transition-all duration-200">
										<span class="text-accent">__</span>read_entry
									</span>
								</div>
							</a>
						);
					})}
				</div>

				{/* End of list indicator */}
				<div class="mt-12 text-center">
					<span class="inline-block w-2.5 h-1 bg-cyber-border animate-pulse"></span>
				</div>
			</div>
		</main>
		<Footer />
	</body>
</html>
