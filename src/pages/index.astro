---
import Metadata from "../components/blog-list-item/Metadata.astro";
import Title from "../components/blog-list-item/Title.astro";
import { SITE_TITLE, SITE_DESCRIPTION } from "../consts";
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";

const posts = (await getCollection("blog")).sort(
	(a, b) =>
		b.data.publishdate.valueOf() - a.data.publishdate.valueOf() ||
		b.id.localeCompare(a.id),
);
---

<BaseLayout title={SITE_TITLE} description={SITE_DESCRIPTION}>
	<main>
		<div class="terminal-header-bar">
			<span class="terminal-prompt">$</span>
			<span class="terminal-command"
				>find ./blog -maxdepth 1 -name "*.md" -type f</span
			>
		</div>

		{
			posts.map((post) => {
				return (
					<a href={`/blog/${post.id}/`} class="group blog-post-link">
						<Metadata slug={post.id} date={post.data.publishdate} />

						<Title title={post.data.title} />

						<span class="indicator-text">READ_ENTRY</span>
					</a>
				);
			})
		}
	</main>
</BaseLayout>

<style>
	main {
		padding-top: 5rem;
		padding-bottom: 4rem;
		max-width: 56rem;
		margin: 0 auto;
		font-family: "Share Tech Mono", monospace;
	}

	.terminal-header-bar {
		font-size: 0.75rem;
		margin: 1rem 0;
		border-bottom: 1px solid var(--border);
		padding-bottom: 1rem;
	}

	@media (min-width: 640px) {
		.terminal-header-bar {
			font-size: 0.875rem;
		}
	}

	.terminal-prompt {
		color: var(--accent);
	}

	.terminal-command {
		color: var(--text-bright);
	}

	.blog-post-link {
		display: flex;
		flex-direction: column;
		margin-top: 0.25rem;
		gap: 0.5rem;
		padding: 0.75rem 1rem;
		border-left: 2px solid transparent;
		transition: all 300ms;
	}

	@media (min-width: 640px) {
		.blog-post-link {
			flex-direction: row;
			gap: 1.5rem;
		}
	}

	.blog-post-link:hover {
		border-left-color: var(--accent);
		background-image: linear-gradient(
			to right,
			rgba(0, 212, 255, 0.1),
			transparent
		);
		transform: translateX(0.25rem);
	}

	.indicator-text {
		display: none;
		opacity: 0;
		margin-left: auto;

		font-size: 10px;
		color: var(--text-body);
		transition: all 300ms;
		letter-spacing: 0.1em;
	}

	@media (min-width: 640px) {
		.indicator-text {
			display: block;
			align-self: center;
		}

		.group:hover .indicator-text {
			opacity: 0.6;
		}
	}
</style>
